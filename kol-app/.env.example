# ====================================
# KOL App 后端环境变量
# ====================================
# 复制此文件为 .env，填入真实值后使用

# MySQL 数据库配置
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=YOUR_DB_PASSWORD
MYSQL_DATABASE=YOUR_DATABASE_NAME

# FastAPI 根路径（部署在子路径时使用）
ROOT_PATH=/kol

# 后端监听端口
PORT=8001
